generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  fullName            String
  fullNameAr          String?
  jobTitle            String?
  phone               String?
  profileImage        String?
  passwordHash        String               @default("")
  status              String               @default("ACTIVE")
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  auditLogs           AuditLog[]
  createdCustomers    Customer[]           @relation("CustomerCreator")
  ownedCustomers      Customer[]           @relation("CustomerOwner")
  passwordResetTokens PasswordResetToken[]
  assignedTasks       Task[]               @relation("TaskAssignee")
  createdTasks        Task[]               @relation("TaskCreator")
  roles               UserRole[]
  directPermissions   UserPermission[]
  notifications       Notification[]
  departments         UserDepartment[]
  taskComments        TaskComment[]
  managedDepartments  Department[]         @relation("DepartmentManager")
  // Internal Task relations
  assignedInternalTasks  InternalTask[]       @relation("InternalTaskAssignee")
  createdInternalTasks   InternalTask[]       @relation("InternalTaskCreator")
  approvedInternalTasks  InternalTask[]       @relation("InternalTaskApprover")
  internalTaskComments   InternalTaskComment[]
  ratingsGiven           TaskRating[]         @relation("RatingGiver")
  ratingsReceived        TaskRating[]         @relation("RatingReceiver")
  performanceReviews     PerformanceReview[]  @relation("ReviewSubject")
  reviewsWritten         PerformanceReview[]  @relation("ReviewWriter")
  // Inventory relations
  createdProducts        Product[]            @relation("ProductCreator")
  stockMovements         StockMovement[]      @relation("StockMovementCreator")
  // Quotation & related relations
  createdQuotations      Quotation[]          @relation("QuotationCreator")
  confirmedQuotations    Quotation[]          @relation("QuotationConfirmer")
  clientApprovedQuotations Quotation[]        @relation("QuotationClientApprover")
  createdPurchaseOrders  PurchaseOrder[]      @relation("PurchaseOrderCreator")
  createdTaxInvoices     TaxInvoice[]         @relation("TaxInvoiceCreator")
  createdDeliveryNotes   DeliveryNote[]       @relation("DeliveryNoteCreator")
  uploadedAttachments    Attachment[]
  createdClients         Client[]             @relation("ClientCreator")
  createdTaxPayments     TaxInvoicePayment[]  @relation("TaxPaymentCreator")
  createdWorkOrders      WorkOrder[]          @relation("WorkOrderCreator")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String             @id @default(uuid())
  name        String             @unique
  resource    String
  action      String
  scope       String?
  description String?
  roles       RolePermission[]
  users       UserPermission[]
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model Customer {
  id              String         @id @default(uuid())
  fullName        String
  fullNameAr      String?
  nationalId      String?        @unique
  phone           String?
  email           String?
  company         String?
  contactPerson   String?
  customerType    String
  status          String         @default("NEW_INQUIRY")
  emirate         String?
  city            String?
  area            String?
  basin           String?
  projectType     String?
  productType     String?
  leadSource      String?
  estimatedValue  Float?
  probability     Int?           @default(10)
  weightedValue   Float?         @default(0)
  consultant              String?
  consultantContactPerson String?
  consultantPhone         String?
  paymentTerms            String?
  projectSize     Float?
  notes           String?
  lastFollowUp    DateTime?
  nextFollowUp    DateTime?
  ownerId         String
  createdById     String
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       User           @relation("CustomerCreator", fields: [createdById], references: [id])
  owner           User           @relation("CustomerOwner", fields: [ownerId], references: [id])
  tasks           Task[]
  attachments     Attachment[]
  quotations      Quotation[]
  taxInvoices     TaxInvoice[]
  deliveryNotes   DeliveryNote[]
  workOrders      WorkOrder[]

  @@index([ownerId])
  @@index([phone])
  @@index([customerType])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([leadSource])
  @@index([emirate])
}

// ==========================================
// Customer Attachments
// ==========================================

model Attachment {
  id              String        @id @default(uuid())
  customerId      String?
  internalTaskId  String?
  quotationId     String?
  taxInvoiceId    String?
  tempSessionId   String?
  category        String
  subcategory     String?
  fileName        String
  originalName    String
  fileSize        Int
  mimeType        String
  filePath        String
  uploadedById    String
  createdAt       DateTime      @default(now())

  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  internalTask    InternalTask? @relation(fields: [internalTaskId], references: [id], onDelete: Cascade)
  quotation       Quotation?    @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  taxInvoice      TaxInvoice?   @relation(fields: [taxInvoiceId], references: [id], onDelete: Cascade)
  uploadedBy      User          @relation(fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@index([customerId])
  @@index([internalTaskId])
  @@index([quotationId])
  @@index([taxInvoiceId])
  @@index([tempSessionId])
  @@index([category])
  @@index([createdAt])
}

// ==========================================
// Department & Team Management
// ==========================================

model Department {
  id              String           @id @default(uuid())
  name            String           @unique
  nameAr          String?
  description     String?
  parentId        String?
  managerId       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  parent          Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  children        Department[]     @relation("DepartmentHierarchy")
  manager         User?            @relation("DepartmentManager", fields: [managerId], references: [id])
  users           UserDepartment[]
  tasks           Task[]
  internalTasks   InternalTask[]
  escalationRules EscalationRule[]

  @@index([parentId])
  @@index([managerId])
}

model UserDepartment {
  id           String     @id @default(uuid())
  userId       String
  departmentId String
  isPrimary    Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
}

// ==========================================
// Task Management & Escalation
// ==========================================

model TaskCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  nameAr      String?
  color       String   @default("#6366f1")
  icon        String?
  createdAt   DateTime @default(now())

  tasks         Task[]
  internalTasks InternalTask[]
}

model Task {
  id              String        @id @default(uuid())
  customerId      String
  assignedToId    String
  title           String
  description     String?
  dueAt           DateTime
  status          String        @default("OPEN")    // OPEN, DONE, OVERDUE, CANCELED
  priority        String        @default("MEDIUM")  // LOW, MEDIUM, HIGH
  completedAt     DateTime?
  createdById     String
  categoryId      String?
  departmentId    String?
  escalationLevel Int           @default(0)         // 0=normal, 1=escalated, 2=critical
  slaDeadline     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  assignedTo      User          @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy       User          @relation("TaskCreator", fields: [createdById], references: [id])
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category        TaskCategory? @relation(fields: [categoryId], references: [id])
  department      Department?   @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  comments        TaskComment[]

  @@index([assignedToId])
  @@index([customerId])
  @@index([status])
  @@index([dueAt])
  @@index([createdAt])
  @@index([categoryId])
  @@index([departmentId])
  @@index([escalationLevel])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  type      String   @default("COMMENT")  // COMMENT, STATUS_CHANGE, REASSIGNMENT, ESCALATION, SYSTEM
  metadata  String?  // JSON string for extra data
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user      User     @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
}

model EscalationRule {
  id              String      @id @default(uuid())
  departmentId    String?
  name            String
  description     String?
  triggerType     String      // OVERDUE_HOURS, OVERDUE_DAYS
  triggerValue    Int         // number of hours/days
  action          String      // NOTIFY_MANAGER, ESCALATE_PRIORITY, REASSIGN, NOTIFY_TEAM
  targetPriority  String?     // target priority if action is ESCALATE_PRIORITY
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  department      Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([departmentId])
  @@index([isActive])
}

// ==========================================
// Internal Task Management & Performance
// ==========================================

model InternalTask {
  id              String               @id @default(uuid())
  title           String
  description     String?
  assignedToId    String
  createdById     String
  departmentId    String?
  categoryId      String?
  status          String               @default("OPEN")     // OPEN, IN_PROGRESS, SUBMITTED, APPROVED, REJECTED, DONE
  priority        String               @default("MEDIUM")   // LOW, MEDIUM, HIGH, URGENT
  dueAt           DateTime?
  completedAt     DateTime?
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedById    String?
  rejectionReason String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  assignedTo      User                 @relation("InternalTaskAssignee", fields: [assignedToId], references: [id])
  createdBy       User                 @relation("InternalTaskCreator", fields: [createdById], references: [id])
  approvedBy      User?                @relation("InternalTaskApprover", fields: [approvedById], references: [id])
  department      Department?          @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  category        TaskCategory?        @relation(fields: [categoryId], references: [id])
  comments        InternalTaskComment[]
  rating          TaskRating?
  attachments     Attachment[]

  @@index([assignedToId])
  @@index([createdById])
  @@index([approvedById])
  @@index([departmentId])
  @@index([categoryId])
  @@index([status])
  @@index([priority])
  @@index([dueAt])
  @@index([createdAt])
}

model InternalTaskComment {
  id             String       @id @default(uuid())
  internalTaskId String
  userId         String
  content        String
  type           String       @default("COMMENT")  // COMMENT, STATUS_CHANGE, SUBMISSION, APPROVAL, REJECTION, SYSTEM
  createdAt      DateTime     @default(now())

  internalTask   InternalTask @relation(fields: [internalTaskId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([internalTaskId])
  @@index([userId])
  @@index([createdAt])
}

model TaskRating {
  id             String       @id @default(uuid())
  internalTaskId String       @unique
  ratedById      String
  ratedUserId    String
  rating         Int                              // 1-5 stars
  comment        String?
  createdAt      DateTime     @default(now())

  internalTask   InternalTask @relation(fields: [internalTaskId], references: [id], onDelete: Cascade)
  ratedBy        User         @relation("RatingGiver", fields: [ratedById], references: [id])
  ratedUser      User         @relation("RatingReceiver", fields: [ratedUserId], references: [id])

  @@index([ratedById])
  @@index([ratedUserId])
  @@index([createdAt])
}

model PerformanceReview {
  id             String   @id @default(uuid())
  userId         String
  reviewerId     String
  period         String                           // MONTHLY, QUARTERLY, ANNUAL
  periodStart    DateTime
  periodEnd      DateTime
  overallRating  Int                              // 1-5 stars
  strengths      String?
  improvements   String?
  notes          String?
  tasksCompleted Int      @default(0)
  tasksOnTime    Int      @default(0)
  averageRating  Float    @default(0)
  status         String   @default("DRAFT")       // DRAFT, PUBLISHED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation("ReviewSubject", fields: [userId], references: [id])
  reviewer       User     @relation("ReviewWriter", fields: [reviewerId], references: [id])

  @@index([userId])
  @@index([reviewerId])
  @@index([period])
  @@index([status])
  @@index([createdAt])
}

// ==========================================
// Clients & Engineers (Sales Documents)
// ==========================================

model Client {
  id             String     @id @default(uuid())
  companyName    String
  companyNameAr  String?
  trn            String?    // Tax Registration Number
  address     String?
  emirate     String?
  city        String?
  phone       String?
  email       String?
  notes       String?
  status      String     @default("ACTIVE") // ACTIVE, INACTIVE
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy   User       @relation("ClientCreator", fields: [createdById], references: [id])
  engineers   Engineer[]
  quotations  Quotation[]
  taxInvoices TaxInvoice[]
  deliveryNotes DeliveryNote[]
  workOrders  WorkOrder[]

  @@index([companyName])
  @@index([status])
  @@index([createdAt])
}

model Engineer {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  nameAr    String?
  mobile    String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quotations  Quotation[]
  taxInvoices TaxInvoice[]
  deliveryNotes DeliveryNote[]

  @@index([clientId])
}

// ==========================================
// Inventory Management
// ==========================================

model ProductCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  nameAr    String?
  color     String    @default("#6366f1")
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  children  ProductCategory[] @relation("CategoryHierarchy")
  products  Product[]

  @@index([parentId])
}

model Product {
  id              String          @id @default(uuid())
  name            String
  nameAr          String?
  sku             String          @unique
  barcode         String?         @unique
  description     String?
  descriptionAr   String?
  categoryId      String?
  productCode     String?                              // LBS, LPD, etc.
  size            String?                              // e.g. 10x20, 60x60
  unitOfMeasure   String          @default("PIECE")   // PIECE, LM (Linear Meter), Nos, KG, METER, LITER, BOX, CARTON, PALLET
  minStockLevel   Int             @default(0)
  maxStockLevel   Int?
  currentStock    Int             @default(0)
  costPrice       Float?
  sellingPrice    Float?
  image           String?
  datasheet       String?
  location        String?
  status          String          @default("ACTIVE") // ACTIVE, INACTIVE, DISCONTINUED
  notes           String?
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  createdBy       User             @relation("ProductCreator", fields: [createdById], references: [id])
  stockMovements  StockMovement[]
  suppliers       ProductSupplier[]
  quotationItems     QuotationItem[]
  purchaseOrderItems PurchaseOrderItem[]
  taxInvoiceItems    TaxInvoiceItem[]
  deliveryNoteItems  DeliveryNoteItem[]

  @@index([categoryId])
  @@index([createdById])
  @@index([status])
  @@index([sku])
  @@index([barcode])
  @@index([createdAt])
}

model StockMovement {
  id            String   @id @default(uuid())
  productId     String
  type          String   // IN, OUT, ADJUSTMENT, RETURN, TRANSFER
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String?
  reference     String?
  createdById   String
  createdAt     DateTime @default(now())

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy     User     @relation("StockMovementCreator", fields: [createdById], references: [id])

  @@index([productId])
  @@index([createdById])
  @@index([type])
  @@index([createdAt])
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  nameAr        String?
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products        ProductSupplier[]
  purchaseOrders  PurchaseOrder[]

  @@index([status])
  @@index([createdAt])
}

model ProductSupplier {
  id           String   @id @default(uuid())
  productId    String
  supplierId   String
  supplierSku  String?
  unitCost     Float?
  leadTimeDays Int?
  createdAt    DateTime @default(now())

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@index([productId])
  @@index([supplierId])
}

// ==========================================
// Quotations & Invoices
// ==========================================

model Quotation {
  id              String          @id @default(uuid())
  quotationNumber String          @unique
  customerId      String?
  clientId        String?                             // FK to Client model
  engineerId      String?                             // FK to Engineer model
  engineerName    String?                             // fallback / override
  mobileNumber    String?                             // fallback / override
  projectName     String?                             // اسم المشروع
  subject         String?
  notes           String?
  terms           String?
  validUntil      DateTime?
  subtotal        Float           @default(0)
  discountPercent Float           @default(0)
  discountAmount  Float           @default(0)
  taxPercent      Float           @default(5)         // UAE VAT 5%
  taxAmount       Float           @default(0)
  deliveryCharges Float           @default(0)
  total           Float           @default(0)
  // DRAFT → SENT → CLIENT_APPROVED → CONFIRMED → CONVERTED
  // Side exits: CLIENT_REJECTED (after SENT), EXPIRED
  status          String          @default("DRAFT")
  sentAt          DateTime?

  // Stage 2: Client response
  clientApprovedAt   DateTime?
  clientRejectedAt   DateTime?
  clientNotes        String?                           // client revision requests or rejection reason
  clientApprovedById String?                           // user who recorded the client response

  // Legacy field kept for backward compat (maps to clientApprovedAt on new records)
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?                             // kept for old REJECTED records

  // Stage 3: Finance confirmation (triggers production / order)
  lpoNumber       String?                             // LPO Number received from client
  paymentTerms    String?                             // Cash / Cheque / Bank Transfer
  confirmedAt     DateTime?                           // Finance confirmation timestamp
  confirmedById   String?                             // Finance user who confirmed
  paymentType     String?                             // DEPOSIT | PARTIAL | FULL_ADVANCE | FULL_ON_DELIVERY
  depositPercent  Float?                              // e.g. 30 for 30%
  depositAmount   Float?                              // calculated deposit amount
  paymentProofUrl String?                             // payment receipt / bank slip URL
  paymentNotes    String?                             // notes from finance team

  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  customer           Customer?       @relation(fields: [customerId], references: [id])
  client             Client?         @relation(fields: [clientId], references: [id])
  engineer           Engineer?       @relation(fields: [engineerId], references: [id])
  createdBy          User            @relation("QuotationCreator", fields: [createdById], references: [id])
  confirmedBy        User?           @relation("QuotationConfirmer", fields: [confirmedById], references: [id])
  clientApprovedBy   User?           @relation("QuotationClientApprover", fields: [clientApprovedById], references: [id])
  items           QuotationItem[]
  taxInvoices     TaxInvoice[]
  deliveryNotes   DeliveryNote[]
  workOrders      WorkOrder[]
  attachments     Attachment[]

  @@index([customerId])
  @@index([clientId])
  @@index([engineerId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([quotationNumber])
  @@index([projectName])
  @@index([engineerName])
}

model QuotationItem {
  id              String    @id @default(uuid())
  quotationId     String
  productId       String?
  description     String
  quantity        Float     @default(1)
  length          Float?                  // for LitBeam (Linear Meter calculation)
  linearMeters    Float?                  // total LM = qty * length
  size            String?                 // product size label e.g. 10x20
  unit            String?                 // LM or Nos
  unitPrice       Float     @default(0)
  discount        Float     @default(0)  // per-line discount %
  total           Float     @default(0)
  sortOrder       Int       @default(0)

  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product         Product?  @relation(fields: [productId], references: [id])

  @@index([quotationId])
  @@index([productId])
}

// ==========================================
// Tax Invoices
// ==========================================

model TaxInvoice {
  id              String           @id @default(uuid())
  invoiceNumber   String           @unique           // SC-671/26 format
  quotationId     String
  customerId      String?
  clientId        String?                            // FK to Client model
  engineerId      String?                            // FK to Engineer model
  customerTrn     String?                            // Customer TRN
  ourVatReg       String?                            // Our VAT Registration #
  dnNumber        String?                            // Delivery Note reference
  engineerName    String?
  mobileNumber    String?
  projectName     String?
  notes           String?
  terms           String?
  subtotal        Float            @default(0)
  discount        Float            @default(0)
  taxPercent      Float            @default(5)
  taxAmount       Float            @default(0)
  deliveryCharges Float            @default(0)
  total           Float            @default(0)
  paidAmount      Float            @default(0)       // sum of confirmed payments
  status          String           @default("UNPAID") // UNPAID, PARTIAL, PAID, CANCELLED
  sentAt          DateTime?
  lpoNumber       String?
  paymentTerms    String?
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  quotation       Quotation        @relation(fields: [quotationId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  client          Client?          @relation(fields: [clientId], references: [id])
  engineer        Engineer?        @relation(fields: [engineerId], references: [id])
  createdBy       User             @relation("TaxInvoiceCreator", fields: [createdById], references: [id])
  items           TaxInvoiceItem[]
  deliveryNotes   DeliveryNote[]
  payments        TaxInvoicePayment[]
  attachments     Attachment[]

  @@index([quotationId])
  @@index([customerId])
  @@index([clientId])
  @@index([engineerId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([invoiceNumber])
}

model TaxInvoicePayment {
  id          String   @id @default(uuid())
  invoiceId   String
  amount      Float
  method      String   @default("Cash") // Cash, Cheque, Bank Transfer
  paymentDate DateTime @default(now())
  reference   String?  // cheque number, transfer ref
  notes       String?
  status      String   @default("CONFIRMED") // PENDING, CONFIRMED
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice     TaxInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy   User       @relation("TaxPaymentCreator", fields: [createdById], references: [id])

  @@index([invoiceId])
  @@index([createdById])
  @@index([paymentDate])
  @@index([status])
}

model TaxInvoiceItem {
  id           String     @id @default(uuid())
  taxInvoiceId String
  productId    String?
  description  String
  quantity     Float      @default(1)
  length       Float?
  linearMeters Float?
  size         String?
  unit         String?
  unitPrice    Float      @default(0)
  total        Float      @default(0)
  sortOrder    Int        @default(0)

  taxInvoice   TaxInvoice @relation(fields: [taxInvoiceId], references: [id], onDelete: Cascade)
  product      Product?   @relation(fields: [productId], references: [id])

  @@index([taxInvoiceId])
  @@index([productId])
}

// ==========================================
// Delivery Notes
// ==========================================

model DeliveryNote {
  id             String             @id @default(uuid())
  dnNumber       String             @unique           // DN-1251/2026 format
  quotationId    String?
  taxInvoiceId   String?
  customerId     String?
  clientId       String?
  engineerId     String?
  engineerName   String?
  mobileNumber   String?
  projectName    String?
  salesmanSign   String?            // Salesman signature (name or image URL)
  receiverName   String?
  receiverSign   String?            // Receiver signature (name or image URL)
  notes          String?
  status         String             @default("DRAFT") // DRAFT, DELIVERED, RETURNED
  deliveredAt    DateTime?
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  quotation      Quotation?         @relation(fields: [quotationId], references: [id])
  taxInvoice     TaxInvoice?        @relation(fields: [taxInvoiceId], references: [id])
  customer       Customer?          @relation(fields: [customerId], references: [id])
  client         Client?            @relation(fields: [clientId], references: [id])
  engineer       Engineer?          @relation(fields: [engineerId], references: [id])
  createdBy      User               @relation("DeliveryNoteCreator", fields: [createdById], references: [id])
  items          DeliveryNoteItem[]

  @@index([quotationId])
  @@index([taxInvoiceId])
  @@index([customerId])
  @@index([clientId])
  @@index([engineerId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([dnNumber])
}

model DeliveryNoteItem {
  id             String       @id @default(uuid())
  deliveryNoteId String
  productId      String?
  description    String
  quantity       Float        @default(1)
  length         Float?
  linearMeters   Float?
  size           String?
  unit           String?
  unitPrice      Float        @default(0)
  total          Float        @default(0)
  sortOrder      Int          @default(0)

  deliveryNote   DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product        Product?     @relation(fields: [productId], references: [id])

  @@index([deliveryNoteId])
  @@index([productId])
}

// ==========================================
// Purchase Orders
// ==========================================

model PurchaseOrder {
  id              String              @id @default(uuid())
  poNumber        String              @unique
  supplierId      String
  subject         String?
  notes           String?
  terms           String?
  expectedDate    DateTime?
  subtotal        Float               @default(0)
  discountPercent Float               @default(0)
  discountAmount  Float               @default(0)
  taxPercent      Float               @default(5)
  taxAmount       Float               @default(0)
  total           Float               @default(0)
  status          String              @default("DRAFT") // DRAFT, SENT, CONFIRMED, PARTIALLY_RECEIVED, RECEIVED, CANCELLED
  sentAt          DateTime?
  confirmedAt     DateTime?
  receivedAt      DateTime?
  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  createdBy       User                @relation("PurchaseOrderCreator", fields: [createdById], references: [id])
  items           PurchaseOrderItem[]

  @@index([supplierId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([poNumber])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String?
  description     String
  quantity        Float         @default(1)
  receivedQty     Float         @default(0)
  unitPrice       Float         @default(0)
  total           Float         @default(0)
  sortOrder       Int           @default(0)

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

// ==========================================
// Work Orders
// ==========================================

model WorkOrder {
  id              String          @id @default(uuid())
  woNumber        String          @unique            // WO-1/26 format
  quotationId     String?
  customerId      String?
  clientId        String?
  engineerName    String?
  mobileNumber    String?
  projectName     String?
  workingDays     Int             @default(1)
  notes           String?
  status          String          @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  quotation       Quotation?      @relation(fields: [quotationId], references: [id])
  customer        Customer?       @relation(fields: [customerId], references: [id])
  client          Client?         @relation(fields: [clientId], references: [id])
  createdBy       User            @relation("WorkOrderCreator", fields: [createdById], references: [id])
  items           WorkOrderItem[]

  @@index([quotationId])
  @@index([customerId])
  @@index([clientId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

model WorkOrderItem {
  id           String    @id @default(uuid())
  workOrderId  String
  description  String
  quantity     Float     @default(1)
  length       Float?
  linearMeters Float?
  size         String?
  unit         String?
  sortOrder    Int       @default(0)

  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

// ==========================================
// Audit & Security
// ==========================================

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String
  before      String?
  after       String?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String    // TASK_ASSIGNED, TASK_DUE, CUSTOMER_UPDATED, SYSTEM, TASK_ESCALATED, TASK_REASSIGNED, TASK_COMMENT, SLA_WARNING
  title     String
  message   String
  link      String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==========================================
// Payroll & HR Module
// ==========================================

model PayrollEmployee {
  id              String   @id @default(uuid())
  empCode         String   @unique               // SC47, NF26, MAISAN05, NW-55
  name            String
  visaType        String                          // SC-MAIN, NF, ALUM, MAISAN, Outside, NW
  costCenter      String                          // Stride Office, Stride Main, National Factory, Maisan Carpentry, Outside Visa
  wpsEntity       String                          // SC, SC-RAK, Maisan, NF, Cash
  paymentMethod   String   @default("WPS")        // WPS, Cash
  basicSalary     Float    @default(0)
  allowances      Float    @default(0)
  totalSalary     Float    @default(0)            // basic + allowances
  otherAllowance  Float    @default(0)            // Watchman / Other monthly allowance
  hoursPerDay     Float    @default(9)            // 8 = office, 9 = field
  status          String   @default("ACTIVE")     // ACTIVE, HOLD, VACATION, TERMINATED
  remarks         String?
  startDate       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  timesheetEntries PayrollTimesheetEntry[]
  payrollEntries   PayrollEntry[]

  @@index([costCenter])
  @@index([visaType])
  @@index([status])
  @@index([empCode])
}

model PayrollProject {
  id              String   @id @default(uuid())
  projectCode     String   @unique               // SC-P50, SC-P86
  projectName     String
  location        String?
  completionPct   Float?   @default(0)
  contractValue   Float?
  consultant      String?
  status          String   @default("ONGOING")   // ONGOING, WORK_DONE, MOBILIZING, HOLD, CANCELLED
  revenue         Float?
  retention       Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  timesheetEntries PayrollTimesheetEntry[]

  @@index([status])
  @@index([projectCode])
}

model PayrollTimesheet {
  id        String   @id @default(uuid())
  month     Int                               // 1-12
  year      Int                               // 2026
  status    String   @default("OPEN")         // OPEN, LOCKED
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries   PayrollTimesheetEntry[]

  @@unique([month, year])
  @@index([year])
  @@index([status])
}

model PayrollTimesheetEntry {
  id           String   @id @default(uuid())
  timesheetId  String
  employeeId   String
  day          Int                             // 1-31
  hours        Float?                          // 8, 9, 10 — null if absent/off
  dayStatus    String   @default("P")          // P=present, A=absent, SICK, OFF, H=holiday
  projectId    String?                         // which project worked on that day
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  timesheet    PayrollTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  employee     PayrollEmployee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project      PayrollProject?  @relation(fields: [projectId], references: [id])

  @@unique([timesheetId, employeeId, day])
  @@index([timesheetId])
  @@index([employeeId])
  @@index([projectId])
}

model PayrollEntry {
  id               String   @id @default(uuid())
  month            Int
  year             Int
  employeeId       String
  basicSalary      Float    @default(0)
  allowances       Float    @default(0)
  otherAllowance   Float    @default(0)       // Watchman / Other
  totalSalary      Float    @default(0)       // basic + allowances
  workDays         Int      @default(0)       // net days worked
  absentDays       Int      @default(0)
  otHours          Float    @default(0)
  otAmount         Float    @default(0)       // OT pay
  absentDeduction  Float    @default(0)       // deduction for absent days
  allowanceAdj     Float    @default(0)       // extra allowances this month
  deduction        Float    @default(0)       // other deductions
  adjustment       Float    @default(0)       // +/- manual adjustment
  grossSalary      Float    @default(0)       // GT / Salaries and Wages
  wpsAmount        Float    @default(0)       // paid via WPS bank transfer
  cashAmount       Float    @default(0)       // paid in cash
  otPayment        Float    @default(0)       // OT paid separately
  totalPayment     Float    @default(0)       // final total
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee         PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([month, year, employeeId])
  @@index([month, year])
  @@index([employeeId])
}
