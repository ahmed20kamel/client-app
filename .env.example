# ============================================
# CRM Pro - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ── Database ──────────────────────────────────
# Development (SQLite)
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL via Vercel Postgres / Neon / Supabase)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ── Clerk Authentication ──────────────────────
# Get keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_KEY_HERE"
CLERK_SECRET_KEY="sk_test_YOUR_KEY_HERE"

# Clerk routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/en/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/en/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/en/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/en/dashboard"

# ── App ───────────────────────────────────────
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email (Resend) ────────────────────────────
# Get key from: https://resend.com
RESEND_API_KEY="re_YOUR_KEY_HERE"
EMAIL_FROM="CRM Pro <noreply@yourdomain.com>"

# ── Real-time Notifications (Pusher) ──────────
# Get keys from: https://pusher.com
NEXT_PUBLIC_PUSHER_KEY="your_pusher_key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
PUSHER_APP_ID="your_app_id"
PUSHER_SECRET="your_pusher_secret"
