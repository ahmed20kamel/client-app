# ============================================
# Stride ERP - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ── Database (PostgreSQL - Neon) ──────────────
# Get connection string from: https://neon.tech
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ── Authentication ────────────────────────────
# REQUIRED: JWT secret for session tokens
# Generate with: openssl rand -base64 64
# Must be at least 32 characters. App will crash if not set.
JWT_SECRET="change-this-to-a-random-64-char-secret-do-not-use-in-production"

# ── App ───────────────────────────────────────
# Set to your Vercel deployment URL in production (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# ── Email (Resend) ────────────────────────────
# Get key from: https://resend.com
RESEND_API_KEY="re_YOUR_KEY_HERE"
EMAIL_FROM="CRM Pro <noreply@yourdomain.com>"

# ── Real-time Notifications (Pusher) ──────────
# Get keys from: https://pusher.com
NEXT_PUBLIC_PUSHER_KEY="your_pusher_key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
PUSHER_APP_ID="your_app_id"
PUSHER_SECRET="your_pusher_secret"

# ── File Storage (Cloudinary) ─────────────────
# Get credentials from: https://cloudinary.com
# NEVER expose CLOUDINARY_API_SECRET to client-side code
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Cron Job Security ─────────────────────────
# REQUIRED if using external cron (e.g. Vercel Cron, Upstash QStash)
# Generate with: openssl rand -hex 32
CRON_SECRET="change-this-to-a-random-secret"
