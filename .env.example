# ============================================
# CRM Pro - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ── Database ──────────────────────────────────
# Development (SQLite)
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL via Vercel Postgres / Neon / Supabase)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ── Authentication ────────────────────────────
# JWT secret for session tokens (use a long random string in production)
JWT_SECRET="change-this-to-a-random-secret-in-production"

# ── App ───────────────────────────────────────
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email (Resend) ────────────────────────────
# Get key from: https://resend.com
RESEND_API_KEY="re_YOUR_KEY_HERE"
EMAIL_FROM="CRM Pro <noreply@yourdomain.com>"

# ── Real-time Notifications (Pusher) ──────────
# Get keys from: https://pusher.com
NEXT_PUBLIC_PUSHER_KEY="your_pusher_key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
PUSHER_APP_ID="your_app_id"
PUSHER_SECRET="your_pusher_secret"
